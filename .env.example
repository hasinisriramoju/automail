# ============================================================
# OnIT India — AI Email Outreach Platform
# Copy this file to .env and fill in your actual values
# ============================================================

# ---- Server ----
PORT=5000
NODE_ENV=development

# ---- MongoDB ----
# Local: mongodb://localhost:27017/onit_autoemail
# Atlas: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/onit_autoemail
MONGODB_URI=mongodb://localhost:27017/onit_autoemail

# ---- Local AI (Ollama) ----
# Ensure Ollama is running on your local machine
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3

# ---- SMTP (Email Sending) ----
# For Gmail: enable 2FA and generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# ---- Sender Identity (OnIT India) ----
# These override onitProfile.js defaults if set here
SENDER_NAME=OnIT India
SENDER_EMAIL=outreach@onitindia.com

# ---- Rate Limiting ----
# Max AI generation requests per 15 minutes per IP
RATE_LIMIT_AI=30
# Max email sends per 15 minutes per IP
RATE_LIMIT_SEND=20

# ---- Campaign Settings ----
# Delay in milliseconds between bulk campaign emails (anti-spam)
CAMPAIGN_DELAY_MS=3000

# ---- Retry Settings ----
MAX_RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
